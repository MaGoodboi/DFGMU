#include <Windows.h>
#include <iostream>
#include <string>
#include <aclapi.h>

void printFileOwner(const std::string& filePath)
{
    PSECURITY_DESCRIPTOR securityDescriptor = nullptr;

    DWORD dwRes = GetNamedSecurityInfoA(
        filePath.c_str(),
        SE_FILE_OBJECT,
        OWNER_SECURITY_INFORMATION,
        nullptr,
        nullptr,
        nullptr,
        nullptr,
        &securityDescriptor
    );

    if (dwRes != ERROR_SUCCESS)
    {
        printf("Unable to retrieve owner information (error %lu)\n", dwRes);
        return;
    }

    PSID ownerSID = nullptr;
    BOOL defaulted = FALSE;

    if (!GetSecurityDescriptorOwner(securityDescriptor, &ownerSID, &defaulted))
    {
        printf("Unable to retrieve SID (error %lu)\n", GetLastError());
        LocalFree(securityDescriptor);
        return;
    }

    char uName[256];
    DWORD userNameSize = sizeof(uName);

    char domainName[256];
    DWORD domainNameSize = sizeof(domainName);

    SID_NAME_USE sidName;

    if (!LookupAccountSidA(
            nullptr,
            ownerSID,
            uName,
            &userNameSize,
            domainName,
            &domainNameSize,
            &sidName))
    {
        printf("Unable to resolve SID (error %lu)\n", GetLastError());
        LocalFree(securityDescriptor);
        return;
    }

    printf("Owner: %s\\%s\n", domainName, uName);

    LocalFree(securityDescriptor);
}

void listFiles(const std::string& directory, bool showHidden, bool recursive, bool showOwner)
{
    std::string basePath = directory;

    if (!basePath.empty() && basePath.back() != '\\')
        basePath += '\\';

    WIN32_FIND_DATAA fileInfo;

    HANDLE hFind = FindFirstFileA((basePath + "*").c_str(), &fileInfo);

    if (hFind == INVALID_HANDLE_VALUE)
    {
        printf("Failed to open directory '%s' (error %lu)\n", directory.c_str(), GetLastError());
        return;
    }

    do
    {
        // 🔴 CRITICAL FIX: skip "." and ".."
        if (strcmp(fileInfo.cFileName, ".") == 0 || strcmp(fileInfo.cFileName, "..") == 0)
            continue;

        bool isHidden = (fileInfo.dwFileAttributes & FILE_ATTRIBUTE_HIDDEN) != 0;
        if (!showHidden && isHidden)
            continue;

        std::string fullPath = basePath + fileInfo.cFileName;

        SYSTEMTIME creationTime;
        FileTimeToSystemTime(&fileInfo.ftCreationTime, &creationTime);

        if (fileInfo.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY)
        {
            printf("%02d-%02d-%04d %02d:%02d:%02d  %-30s <DIR>\n",
                creationTime.wMonth, creationTime.wDay, creationTime.wYear,
                creationTime.wHour, creationTime.wMinute, creationTime.wSecond,
                fileInfo.cFileName);

            // 🔴 Avoid recursion loops (junctions/symlinks)
            if (recursive &&
                !(fileInfo.dwFileAttributes & FILE_ATTRIBUTE_REPARSE_POINT))
            {
                listFiles(fullPath, showHidden, recursive, showOwner);
            }
        }
        else
        {
            // 🔴 FIXED file size calculation
            ULONGLONG fileSize =
                ((ULONGLONG)fileInfo.nFileSizeHigh << 32) | fileInfo.nFileSizeLow;

            printf("%02d-%02d-%04d %02d:%02d:%02d  %-40s %llu bytes\n",
                creationTime.wMonth, creationTime.wDay, creationTime.wYear,
                creationTime.wHour, creationTime.wMinute, creationTime.wSecond,
                fileInfo.cFileName, fileSize);

            if (showOwner)
            {
                printFileOwner(fullPath);
            }
        }

    } while (FindNextFileA(hFind, &fileInfo));

    FindClose(hFind);
}

int main(int argc, char* argv[])
{
    std::string directory = ".";

    bool showHidden = false;
    bool recursive = false;
    bool showOwner = false;

    for (int i = 1; i < argc; ++i)
    {
        std::string arg = argv[i];

        if (arg == "/a")
            showHidden = true;
        else if (arg == "/d")
            recursive = true;
        else if (arg == "/o")
            showOwner = true;
        else
            directory = arg;
    }

    listFiles(directory, showHidden, recursive, showOwner);

    return 0;
}
